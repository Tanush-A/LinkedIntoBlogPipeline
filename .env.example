OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5                # flagship — draft, critique, revise passes
OPENAI_MODEL_EXTRACT=gpt-5.4-mini   # mini-class — extract pass (simple structured extraction)
SLACK_WEBHOOK_URL=
DEVTO_API_KEY=             # dev.to personal API key: https://dev.to/settings/account → DEV API Keys
DEVTO_DRAFT_MODE=true      # set to true for test runs (published:false); remove/set false for real live publish
BASE_URL=http://localhost:3000
DATABASE_URL=./db/pipeline.sqlite
MAX_REVISIONS=3
PORT=3000

# ── Ingestion (Session 2) ──────────────────────────────────────────────────
SOURCE_MODE=seed                # 'seed' (default, deterministic fallback) | 'live' (LinkdAPI)
LINKDAPI_KEY=                   # unofficial LinkedIn scraper; header X-linkdapi-apikey
PROFILE_ID=justinshriber        # vanity username (auto-resolved to URN) or a raw member URN
POLL_INTERVAL_MINUTES=60        # npm run watch cadence (trial credits are finite)
MIN_POST_CHARS=400              # prefilter: posts shorter than this are discarded (too-short)
BACKFILL_POST_TEXT=true         # /posts/all omits text for ~1/3 of posts; backfill from /posts/info
MAX_POSTS_PER_CYCLE=0           # 0 = unlimited; else only process the newest N (watcher defaults to 20 if unset)
MAX_DRAFTS_PER_CYCLE=0          # 0 = unlimited; cap drafts/cycle (watcher defaults to 5 if unset — credit/Slack guard)
GROUP_CONFIDENCE_MIN=0.6        # judge groups below this confidence are split into singletons
